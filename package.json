{
  "name": "douyin-vedio",
  "version": "1.0.0",
  "description": "古诗词AI视频生成与管理工具",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on http://localhost:5173 && tsc -p tsconfig.main.json && node scripts/start-electron.js --dev",
    "build": "tsc -p tsconfig.main.json && vite build",
    "build:win": "npm run build && electron-builder --win --x64",
    "start": "node scripts/start-electron.js",
    "typecheck": "tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "dotenv": "^16.4.1",
    "electron": "^28.3.3",
    "fluent-ffmpeg": "^2.1.3",
    "sql.js": "^1.10.3"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron-builder": "^24.9.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.douyin.vedio",
    "productName": "古诗词视频工坊",
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": ".env",
        "to": ".env"
      },
      {
        "from": "assets",
        "to": "assets"
      }
    ],
    "files": [
      "dist/**/*",
      "resources/**/*",
      "scripts/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "resources/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "asar": true
  }
}
